# CONFIGURAÇÕES DE BACKUP - KINEOS
# Copie este arquivo para .env.backup e preencha as informações

# URL de Conexão do Supabase (Aba Settings > Database > Connection String > URI)
# IMPORTANTE: Use a porta 5432 (Transaction Mode) ou 6543 (Session Mode) conforme sua necessidade.
# Exemplo: postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://seu_usuario:sua_senha@seu_host:5432/postgres

# Caminho para salvar os backups (Opcional, padrão é a pasta /backups na raiz)
# BACKUP_PATH=/caminho/personalizado/backups

# Dias para manter no histórico
# RETENTION_DAYS=7
